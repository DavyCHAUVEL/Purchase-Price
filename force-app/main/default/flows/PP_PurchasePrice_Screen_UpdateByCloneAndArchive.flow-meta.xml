    <formulas>
        <name>formula_CaclulateExpiryDate</name>
        <dataType>Date</dataType>
        <expression>IF(ISBLANK({!Start_Validity_Date}), {!$Flow.CurrentDate}, {!Start_Validity_Date} - 1)</expression>
    </formulas>
    <formulas>
        <name>Formula_NewPurchasePriceLink</name>
        <dataType>String</dataType>
        <expression>HYPERLINK(&quot;/&quot; &amp; {!newPurchasePriceId}, &quot;Voir le record&quot;)</expression>
    </formulas>
    <formulas>
        <name>Formula_PreviousPurchasePrice</name>
        <dataType>Number</dataType>
        <expression>BLANKVALUE({!Get_Purchase_Price.Purchase_Price__c}, 0)</expression>
        <scale>6</scale>
    </formulas>
    <formulas>
        <name>Formula_NewPurchasePriceValue</name>
        <dataType>Number</dataType>
        <expression>BLANKVALUE({!Purchase_Price}, 0)</expression>
        <scale>6</scale>
    </formulas>
    <formulas>
        <name>Formula_PurchasePriceIncreasePercent</name>
        <dataType>Number</dataType>
        <expression>IF(
{!Formula_PreviousPurchasePrice} = 0,
0,
(({!Formula_NewPurchasePriceValue} - {!Formula_PreviousPurchasePrice}) / {!Formula_PreviousPurchasePrice}) * 100
)</expression>
        <scale>2</scale>
    </formulas>
