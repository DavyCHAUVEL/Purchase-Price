        <rules>
            <name>Start_Validity_Date_In_Future</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Start_Validity_Date</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <elementReference>$Flow.CurrentDate</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Create_Future_New_Purchase_Price</targetReference>
            </connector>
